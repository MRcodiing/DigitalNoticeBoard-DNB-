<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
         http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
         version="3.0">

  <display-name>Digital Notice Board</display-name>

  <servlet>
    <servlet-name>UploadNoticeServlet</servlet-name>
    <servlet-class>file.UploadNoticeServlet</servlet-class>
  </servlet>

  <!-- URL Mapping -->
  <servlet-mapping>
    <servlet-name>UploadNoticeServlet</servlet-name>
    <url-pattern>/us</url-pattern>
  </servlet-mapping>



  <servlet>
    <servlet-name>UplodAssignmentsServlet</servlet-name>
    <servlet-class>file.UplodAssignmentsServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>UplodAssignmentsServlet</servlet-name>
    <url-pattern>/ua</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>DownlodeFile</servlet-name>
    <servlet-class>file.DownlodeFile</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>DownlodeFile</servlet-name>
    <url-pattern>/Downlode</url-pattern>
  </servlet-mapping>






</web-app>
